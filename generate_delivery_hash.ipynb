   "source": [
    "import secrets\n",
    "import hashlib\n",
    "import binascii\n",
    "password = 'delivery123'\n",
    "salt = secrets.token_bytes(16)\n",
    "hash_bytes = hashlib.pbkdf2_hmac('sha512', password.encode('utf-8'), salt, 120000, dklen=64)\n",
    "print(binascii.hexlify(salt).decode())\n",
    "print(binascii.hexlify(hash_bytes).decode())"
   ]
  }
